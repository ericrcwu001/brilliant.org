# Copy to .env.local and fill in for Group C (Firebase). Group A runs fully
# local with no cloud services, so none of these are required yet.

# Firebase web app config (Group C — Auth, Firestore, Hosting)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Firebase App Check (Group C — required before public deploy)
VITE_FIREBASE_APPCHECK_SITE_KEY=
