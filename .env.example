# Firebase web config (Group C). Copy real values into the gitignored env files:
#   .env.development  -> dev project (brilliant-phht-dev),  emulators on
#   .env.production   -> prod project (brilliant-phht-prod), emulators off
# Fetch values from the Firebase console (Project settings -> Your apps -> Web)
# or `firebase apps:sdkconfig web`.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Google Analytics measurement id (G-XXXX). Enables Firebase Analytics events
# (Phase 19). Optional; analytics is skipped in emulator/dev mode regardless.
VITE_FIREBASE_MEASUREMENT_ID=

# "true" connects the SDK to the local Emulator Suite (Auth + Firestore +
# Functions). Default in .env.development; always "false"/unset in production.
VITE_USE_EMULATORS=true

# Firebase App Check (Phase 18 — required before public deploy). reCAPTCHA v3
# site key. Leave blank for emulator dev.
VITE_FIREBASE_APPCHECK_SITE_KEY=
