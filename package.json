    "@gsap/react": "^2.1.2",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-popover": "^1.1.17",
    "@radix-ui/react-tabs": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.10",
    "firebase": "^12.15.0",
    "gsap": "^3.15.0",
    "katex": "^0.17.0",
    "konva": "10.3.0",
    "motion": "^12.41.0",
    "react": "^19.2.6",
    "react-aria": "^3.50.0",
    "react-dom": "^19.2.6",
    "react-konva": "19.2.5",
    "zod": "^4.4.3"
