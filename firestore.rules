rules_version = '2';

// Production rules (Phase 18) — the PRD "Firestore Security Rules Requirements"
// matrix, hardened:
//   - courses/lessons: any signed-in user reads; client never writes (Admin SDK
//     seeds them).
//   - users/{uid}: owner-only; create-once; display-name field whitelist.
//   - snapshots: owner-only; field whitelist that REJECTS unknown keys, so the
//     client cannot smuggle progression fields into a snapshot write.
//   - progress: owner reads; client may write non-authoritative draft fields
//     (e.g. currentBeat) but is DENIED the progression fields, which only Cloud
//     Functions (Admin SDK, bypasses rules) may write.
//   - milestones/streaks: owner reads; all client writes denied (Cloud Functions
//     only).
//
// App Check: enforced for Firestore + Functions in the Firebase console before
// the public deploy (not expressible in rules). The client wires App Check in
// src/firebase/app.ts.
service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function validDisplayName(name) {
      return name is string && name.size() > 0 && name.size() <= 40;
    }

    // Seeded content: any signed-in user reads; client never writes.
    match /courses/{courseId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /lessons/{lessonId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // User-owned data.
    match /users/{uid} {
      allow read: if isOwner(uid);

      // Create-once profile, whitelisted to display-name fields. (`create` only
      // fires when the doc does not yet exist, so this is inherently once.)
      allow create: if isOwner(uid)
        && request.resource.data.keys().hasOnly([
          'displayName', 'createdAt', 'lastActiveAt'
        ])
        && validDisplayName(request.resource.data.displayName);

      // Profile edit (displayName + activity stamp) OR onboarding survey write
      // (6 answer/derived fields + timestamps). validDisplayName is only required
      // when displayName is actually changing.
      allow update: if isOwner(uid)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'displayName', 'lastActiveAt',
          'learningGoal', 'comfortLevel', 'focusArea', 'pace',
          'defaultTrack', 'recommendedConceptId', 'onboardingCompletedAt'
        ])
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['displayName'])
            || validDisplayName(request.resource.data.displayName));

      allow delete: if false;

      // Client-authoritative interaction snapshot. Field whitelist rejects any
      // unknown key (anti-smuggling), so progression fields cannot ride along.
      match /snapshots/{lessonId} {
        allow read: if isOwner(uid);
        allow write: if isOwner(uid)
          && request.resource.data.keys().hasOnly([
            'lessonId', 'beatId', 'pattern', 'completedBeats',
            'interactionState', 'updatedAt', 'schemaVersion'
          ]);
      }

      // Read cache. Client may write non-authoritative draft fields, but the
      // progression fields below are Cloud-Functions-only (denied to the client
      // on both create and update).
      match /progress/{lessonId} {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid)
          && !request.resource.data.keys().hasAny([
            'completionStatus', 'masteryStatus', 'needsReview',
            'unlocks', 'derived', 'transferAttained'
          ]);
        allow update: if isOwner(uid)
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
            'completionStatus', 'masteryStatus', 'needsReview',
            'unlocks', 'derived', 'transferAttained'
          ]);
        allow delete: if false;
      }

      // Cloud Functions only (Admin SDK bypasses rules).
      match /milestones/{milestoneId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }
      match /streaks/{docId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }
    }
  }
}
