{
  "paper-shadow-1": { "$value": "0 1px 2px rgba(22, 26, 39, 0.06), 0 1px 3px rgba(22, 26, 39, 0.04)", "$type": "shadow" },
  "paper-shadow-2": { "$value": "0 6px 16px rgba(22, 26, 39, 0.08)",                                   "$type": "shadow" },
  "paper-shadow-3": { "$value": "0 16px 40px rgba(22, 26, 39, 0.12)",                                  "$type": "shadow" },
  "press-deboss":   { "$value": "inset 0 1px 2px rgba(22, 26, 39, 0.12)",                              "$type": "shadow" },
  "edge-highlight": { "$value": "0 1px 0 rgba(255, 255, 255, 0.55)",                                   "$type": "shadow" },
  "letterpress-ink":{ "$value": "0 1px 0 rgba(255, 255, 255, 0.5)",                                    "$type": "shadow" },
  "e1":             { "$value": "var(--paper-shadow-1)",                                                "$type": "shadow" },
  "e2":             { "$value": "var(--paper-shadow-2)",                                                "$type": "shadow" },
  "ergo-shadow-sm": { "$value": "0 1px 2px rgba(22, 26, 39, 0.06), 0 1px 3px rgba(22, 26, 39, 0.04)", "$type": "shadow" },
  "ergo-shadow-md": { "$value": "0 6px 16px rgba(22, 26, 39, 0.08)",                                   "$type": "shadow" },
  "ergo-shadow-lg": { "$value": "0 16px 40px rgba(22, 26, 39, 0.12)",                                  "$type": "shadow" },
  "ring-focus":     { "$value": "0 0 0 3px rgba(79, 70, 229, 0.35)",                                   "$type": "shadow" }
}
